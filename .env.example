app_name=诗经事物 API
app_version=1.0.0
database_url=sqlite:///./shijing.db

admin_username=qtmuniao
admin_password=xiaosong

secret_key=replace-with-a-long-random-secret
access_token_expire_minutes=10080
session_https_only=false
session_same_site=lax

github_client_id=
github_client_secret=
github_redirect_uri=https://shi.qtmuniao.com/auth/github/callback

wechat_app_id=
wechat_app_secret=
wechat_redirect_uri=https://shi.qtmuniao.com/auth/wechat/callback

default_max_comments_per_page=3
comment_approval_required=false
comment_cooldown_seconds=30
max_comments_per_hour_per_user=10
max_comments_per_hour_per_ip=20
max_comments_per_day_per_ip=50
enable_ip_blacklist=true
enable_spam_filter=true
